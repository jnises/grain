{
  "name": "grain",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stop": "node scripts/stop-dev-server.js",
    "dev:restart": "npm run dev:stop && npm run dev",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "check": "npm run lint && npm run type-check",
    "preview": "vite preview",
    "test:watch": "vitest",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "benchmark": "vitest run --config vitest.benchmark.config.ts",
    "profile:flamegraph": "NODE_ENV=production npx tsx scripts/profiling/flamegraph_profiler.ts",
    "profile:simple": "NODE_ENV=production npx tsx scripts/profiling/simple_profiler.ts",
    "profile:hotspots": "NODE_ENV=production scripts/profiling/profile_hotspots.sh",
    "profile": "npm run profile:flamegraph",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "minimatch": "^10.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "find-process": "^2.0.0",
    "fkill-cli": "^8.0.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
